#!/bin/sh
set -eu

AGENTWS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$AGENTWS_ROOT/bin/lib-agentws"

if [ -d "$JOBS_DIR" ]; then
    echo "jobs/ directory already exists."
else
    mkdir -p "$JOBS_DIR"
    echo "Created jobs/ directory."
fi

if [ -d "$AGENTWS_ROOT/agents" ]; then
    echo "agents/ directory already exists."
else
    mkdir -p "$AGENTWS_ROOT/agents"
    echo "Created agents/ directory."
fi

echo "AgentWS initialized at: $AGENTWS_ROOT"
echo ""
echo "Next steps:"
echo "  1. Write a complete task:  \$EDITOR /tmp/my-first-task.md"
echo "  2. Create the task:        bin/task-create \"My first task\" /tmp/my-first-task.md"
echo "  3. Start a planner:        tools/agent --pi planner planner-1"
