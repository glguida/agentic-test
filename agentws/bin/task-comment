#!/bin/sh
set -eu

AGENTWS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$AGENTWS_ROOT/bin/lib-agentws"

usage() {
    echo "Usage: task-comment <task-id> <message>"
    exit 1
}

[ "$#" -ge 2 ] || usage

TASK_ID="$1"
shift
MESSAGE="$*"

validate_task_id "$TASK_ID"
[ -n "$MESSAGE" ] || die "message required"

"$AGENTWS_ROOT/bin/task-github" comment "$TASK_ID" "$MESSAGE"
echo "$TASK_ID: comment added"
