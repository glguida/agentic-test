#!/bin/sh
set -eu

AGENTWS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$AGENTWS_ROOT/bin/lib-agentws"

usage() {
    echo "Usage: task-create <issue-title> <spec-file>"
    echo ""
    echo "Create a task through the GitHub-backed task tool. With remote jobs, the webhook creates the planner job."
    exit 1
}

create_initial_planner_job() {
    task_id="$1"
    issue_url="$2"

    PLAN_JOB_ID="$task_id-plan"

    [ ! -e "$JOBS_DIR/$PLAN_JOB_ID" ] || die "initial planner job '$PLAN_JOB_ID' already exists"

    tmp_spec="${TMPDIR:-/tmp}/agentws-$task_id-plan-spec.$$"
    cat > "$tmp_spec" <<EOF
# Plan for task $task_id

## Task
$task_id

## Task Source
$issue_url

## Objective
Read the task with \`bin/task-show $task_id\`, update task understanding with
\`bin/task-comment $task_id <message>\`, and create the first jobs needed to
complete this task.

## Acceptance Criteria
The task has a clear initial plan, and any jobs needed next have been created
with \`task-id=$task_id\`.

## When Done
Create the required follow-up jobs for this task, then close this planner job.
The task is complete only when a planner decides it is complete and records the
result with \`bin/task-result $task_id <result-file>\`.
EOF

    if ! "$AGENTWS_ROOT/bin/job-create" "$PLAN_JOB_ID" -r planner -t "$task_id" "$tmp_spec"; then
        rm -f "$tmp_spec"
        exit 1
    fi

    rm -f "$tmp_spec"
}

TITLE=""
SPEC_FILE=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        --help|-h)
            usage
            ;;
        *)
            if [ -z "$TITLE" ]; then
                TITLE="$1"
            elif [ -z "$SPEC_FILE" ]; then
                SPEC_FILE="$1"
            else
                die "unexpected argument '$1'"
            fi
            shift
            ;;
    esac
done

[ -n "$TITLE" ] || usage
[ -n "$SPEC_FILE" ] || die "spec file required"
[ "$SPEC_FILE" = "-" ] && die "pass a spec file path, not stdin"
[ -f "$SPEC_FILE" ] || die "spec file '$SPEC_FILE' does not exist"
[ -s "$SPEC_FILE" ] || die "spec file '$SPEC_FILE' is empty"

require_jobs_dir

create_output="$("$AGENTWS_ROOT/bin/task-github" create "$TITLE" "$SPEC_FILE")"
TASK_ID="$(printf '%s\n' "$create_output" | sed -n '1p')"
TASK_URL="$(printf '%s\n' "$create_output" | sed -n '2p')"

validate_task_id "$TASK_ID"

echo "task id: $TASK_ID"
echo "github issue: $TASK_URL"

if remote_jobs_enabled; then
    echo "initial planner job: created by GitHub webhook"
else
    create_initial_planner_job "$TASK_ID" "$TASK_URL"
    echo "initial planner job: $JOBS_DIR/$TASK_ID-plan"
fi
