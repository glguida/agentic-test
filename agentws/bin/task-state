#!/bin/sh
set -eu

AGENTWS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$AGENTWS_ROOT/bin/lib-agentws"

usage() {
    echo "Usage: task-state <task-id> <open|pr-sent> [-m <message>]"
    exit 1
}

TASK_ID=""
STATE=""
MESSAGE=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        -m)
            [ "$#" -ge 2 ] || die "-m requires a message"
            MESSAGE="$2"
            shift 2
            ;;
        --help|-h)
            usage
            ;;
        *)
            if [ -z "$TASK_ID" ]; then
                TASK_ID="$1"
            elif [ -z "$STATE" ]; then
                STATE="$1"
            else
                die "unexpected argument '$1'"
            fi
            shift
            ;;
    esac
done

[ -n "$TASK_ID" ] || usage
[ -n "$STATE" ] || usage

validate_task_id "$TASK_ID"
require_valid_task_state "$STATE"

"$AGENTWS_ROOT/bin/task-github" state "$TASK_ID" "$STATE" "$MESSAGE"
echo "$TASK_ID: state -> $STATE"
