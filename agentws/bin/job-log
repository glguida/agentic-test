#!/bin/sh
set -eu

AGENTWS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$AGENTWS_ROOT/bin/lib-agentws"

if remote_jobs_enabled; then
    exec "$AGENTWS_ROOT/bin/job-remote" log "$@"
fi

usage() {
    echo "Usage: job-log <job-id> [--agent-id <agent-id>] -s <summary> [-d <detail>]"
    exit 1
}

JOB_ID=""
AGENT_ID=""
SUMMARY=""
DETAIL=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        --agent-id)
            [ "$#" -ge 2 ] || die "$1 requires an agent ID"
            AGENT_ID="$2"
            shift 2
            ;;
        -s|--summary)
            [ "$#" -ge 2 ] || die "$1 requires a summary"
            SUMMARY="$2"
            shift 2
            ;;
        -d|--detail)
            [ "$#" -ge 2 ] || die "$1 requires detail"
            DETAIL="$2"
            shift 2
            ;;
        --help|-h)
            usage
            ;;
        *)
            if [ -z "$JOB_ID" ]; then
                JOB_ID="$1"
            else
                die "unexpected argument '$1'"
            fi
            shift
            ;;
    esac
done

[ -n "$JOB_ID" ] || usage
[ -n "$SUMMARY" ] || die "-s <summary> is required"

validate_job_id "$JOB_ID"
[ -z "$AGENT_ID" ] || validate_agent_id "$AGENT_ID"
require_jobs_dir

JOB_DIR="$JOBS_DIR/$JOB_ID"
[ -d "$JOB_DIR" ] || die "job '$JOB_ID' does not exist"

if [ -n "$AGENT_ID" ]; then
    require_agent_owner "log" "$JOB_ID" "$JOB_DIR" "$AGENT_ID"
fi

append_log "$JOB_DIR" "$SUMMARY" "$DETAIL"
echo "$JOB_ID: log appended"
