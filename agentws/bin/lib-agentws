#!/bin/sh

JOBS_DIR="${JOBS_DIR:-$AGENTWS_ROOT/jobs}"
TASKS_DIR="${TASKS_DIR:-$AGENTWS_ROOT/tasks}"
VALID_STATUSES="${VALID_STATUSES:-pending claimed running done failed}"
VALID_TASK_STATES="${VALID_TASK_STATES:-open pr-sent}"
AGENTWS_CONFIG="${AGENTWS_CONFIG:-$AGENTWS_ROOT/config}"

die() {
    echo "error: $*" >&2
    exit 1
}

timestamp() {
    date -u +%Y-%m-%dT%H:%M:%SZ
}

agent_host() {
    hostname 2>/dev/null || uname -n
}

validate_name() {
    label="$1"
    value="${2:-}"

    case "$value" in
        ""|*[!A-Za-z0-9._-]*)
            die "invalid $label '$value' - only alphanumeric, dot, underscore, and hyphen allowed"
            ;;
    esac
}

validate_job_id() {
    validate_name "job ID" "${1:-}"
}

validate_task_id() {
    validate_name "task ID" "${1:-}"
}

validate_role() {
    validate_name "role" "${1:-}"
}

validate_agent_id() {
    validate_name "agent ID" "${1:-}"
}

is_valid_status() {
    candidate="${1:-}"

    for status in $VALID_STATUSES; do
        [ "$status" = "$candidate" ] && return 0
    done

    return 1
}

require_valid_status() {
    status="${1:-}"

    if ! is_valid_status "$status"; then
        echo "error: invalid status '$status'" >&2
        echo "valid statuses: $VALID_STATUSES" >&2
        exit 1
    fi
}

is_valid_task_state() {
    candidate="${1:-}"

    for state in $VALID_TASK_STATES; do
        [ "$state" = "$candidate" ] && return 0
    done

    return 1
}

require_valid_task_state() {
    state="${1:-}"

    if ! is_valid_task_state "$state"; then
        echo "error: invalid task state '$state'" >&2
        echo "valid task states: $VALID_TASK_STATES" >&2
        exit 1
    fi
}

config_get() {
    key="$1"
    default="${2:-}"

    if [ ! -f "$AGENTWS_CONFIG" ]; then
        printf '%s\n' "$default"
        return 0
    fi

    while IFS= read -r line || [ -n "$line" ]; do
        case "$line" in
            ""|\#*) continue ;;
            "$key="*)
                printf '%s\n' "${line#*=}"
                return 0
                ;;
        esac
    done < "$AGENTWS_CONFIG"

    printf '%s\n' "$default"
}

remote_jobs_enabled() {
    [ -n "${AGENTWS_SERVER_URL:-}" ] && return 0
    [ -n "${AGENTWS_SERVER_FILE:-}" ] && [ -f "$AGENTWS_SERVER_FILE" ] && return 0
    [ -f "$AGENTWS_ROOT/server.url" ] && return 0
    return 1
}

require_jobs_dir() {
    [ -d "$JOBS_DIR" ] || die "jobs directory '$JOBS_DIR' does not exist; run bin/job-init first"
}

require_tasks_dir() {
    [ -d "$TASKS_DIR" ] || die "tasks directory '$TASKS_DIR' does not exist; run bin/job-init first"
}

require_positive_integer() {
    name="$1"
    value="${2:-}"

    case "$value" in
        ""|*[!0-9]*)
            die "$name must be a positive integer"
            ;;
    esac

    [ "$value" -gt 0 ] || die "$name must be greater than zero"
}

read_status() {
    job_dir="$1"
    cat "$job_dir/status" 2>/dev/null || echo "unknown"
}

write_file_atomic() {
    path="$1"
    content="$2"
    tmp="$path.tmp.$$"

    printf '%s\n' "$content" > "$tmp" || die "cannot write temporary file '$tmp'"
    mv -f "$tmp" "$path" || {
        rm -f "$tmp"
        die "cannot replace '$path'"
    }
}

require_agent_owner() {
    action="$1"
    job_id="$2"
    job_dir="$3"
    agent_id="$4"

    validate_agent_id "$agent_id"
    [ -f "$job_dir/agent-id" ] || die "cannot $action job '$job_id': missing agent-id"
    expected="$(cat "$job_dir/agent-id" 2>/dev/null || true)"

    if [ "$expected" != "$agent_id" ]; then
        die "cannot $action job '$job_id': owned by '$expected', not '$agent_id'"
    fi
}

append_log() {
    job_dir="$1"
    summary="$2"
    detail="${3:-}"

    {
        printf '## %s - %s\n\n' "$(timestamp)" "$summary"
        if [ -n "$detail" ]; then
            printf '%s\n\n' "$detail"
        fi
    } >> "$job_dir/log.md"
}

append_task_log() {
    task_dir="$1"
    summary="$2"
    detail="${3:-}"

    {
        printf '## %s - %s\n\n' "$(timestamp)" "$summary"
        if [ -n "$detail" ]; then
            printf '%s\n\n' "$detail"
        fi
    } >> "$task_dir/log.md"
}
